# ─── Angel One API ───
# Get these from your Angel One developer dashboard
ANGELONE_API_KEY=
ANGELONE_CLIENT_CODE=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=
ANGELONE_SECRET_KEY=

# ─── Authentication ───
SECRET_KEY=papertradingsecret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Credential Encryption ───
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ─── Google OAuth ───
GOOGLE_CLIENT_ID=

# ─── SMTP (Password Reset) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Paper Trading

# ─── Frontend / CORS ───
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ─── Twilio (Phone OTP) ───
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Database ───
# Leave empty to use SQLite (./paper_trading.db)
# For PostgreSQL: postgresql://user:password@host:5432/papertrading
DATABASE_URL=

# ─── Admin Emails ───
# Comma-separated list of emails that have admin dashboard access
ADMIN_EMAILS=

# ─── Misc ───
AUTO_SYNC_STOCKS=true
SMARTAPI_SESSION_TTL_SECONDS=28800
LTP_CACHE_SECONDS=5

# ─── Market Hours (International Support) ───
# For other countries, change timezone and market open/close times
# Examples: "America/New_York", "Europe/London", "Asia/Tokyo"
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
