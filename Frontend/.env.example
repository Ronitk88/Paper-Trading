# ─── Local Development ───
# VITE_API_BASE_URL=http://127.0.0.1:8000

# ─── Production (Vercel frontend + Digital Ocean backend) ───
# Set this to your Digital Ocean backend URL:
# VITE_API_BASE_URL=https://your-app.ondigitalocean.app

VITE_API_BASE_URL=http://127.0.0.1:8000

# ─── Google OAuth ───
# Required for Google login. Get from Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=your-google-client-id
